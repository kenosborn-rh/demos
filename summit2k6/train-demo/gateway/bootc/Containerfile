FROM registry.redhat.io/rhel9/rhel-bootc:9.7

RUN dnf install -y \
    gdm \
    gnome-shell \
    gnome-session \
    gnome-terminal \
    firefox \
    podman \
    cockpit \
    cockpit-podman \
    firewalld \
    sudo \
    openssh-server \
    python3 \
    python3-pip \
    mesa-libGL \
    libglvnd-glx \
    iputils \
    iproute \
    bind-utils \
    net-tools \
    nmap-ncat \
    tcpdump \
    git \
    vim \
    jq \
    tmux \
    && dnf clean all


# Install Edge Manager agent
RUN dnf config-manager --add-repo https://rpm.flightctl.io/flightctl-lab.repo && \
    dnf clean all && \
    dnf -y install flightctl-agent-0:1.1.0~main~118~g55455431.lab-1.el9.x86_64 && \
    systemctl enable flightctl-agent.service


# Copy early binding enrollment config
COPY config.yaml /etc/flightctl/config.yaml


# Create demo user (bootc uses /var/home)
RUN mkdir -p /var/home && \
    useradd -m -d /var/home/demouser -s /bin/bash demouser

RUN mkdir -p /var/home/demouser && \
    chown -R demouser:demouser /var/home/demouser && \
    rm -rf /var/home/demouser/.mozilla || true


# Add demouser to wheel
RUN usermod -aG wheel demouser


# Passwordless sudo
RUN echo "demouser ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/demouser && \
    chmod 0440 /etc/sudoers.d/demouser


# Root password for troubleshooting
# DO NOT DO THIS IN PRODUCTION
RUN echo "root:redhat123" | chpasswd && \
    passwd -u root


# Preconfigure NetworkManager autoconnect for NIC
RUN mkdir -p /etc/NetworkManager/system-connections && \
    printf "[connection]\nid=primary\ntype=ethernet\nautoconnect=true\nautoconnect-priority=100\n\n[ethernet]\nmac-address=58:47:CA:78:F2:58\n\n[ipv4]\nmethod=auto\n\n[ipv6]\nmethod=auto\n" \
    > /etc/NetworkManager/system-connections/primary.nmconnection && \
    chmod 600 /etc/NetworkManager/system-connections/primary.nmconnection


# Enable required services
RUN systemctl enable cockpit.socket
RUN systemctl enable NetworkManager
RUN systemctl enable sshd
RUN systemctl enable gdm


# Disable NM wait-online (can delay boot)
RUN systemctl disable NetworkManager-wait-online.service || true


# Allow SSH through firewall
RUN firewall-offline-cmd --add-service=ssh


# Boot to graphical desktop
RUN systemctl set-default graphical.target


# Enable automatic login
RUN mkdir -p /etc/gdm && \
    printf '[daemon]\nAutomaticLoginEnable=True\nAutomaticLogin=demouser\nInitialSetupEnable=False\n' > /etc/gdm/custom.conf


# Disable screen lock and sleep
RUN mkdir -p /etc/dconf/db/local.d /etc/dconf/db/local.d/locks && \
    printf '[org/gnome/desktop/session]\nidle-delay=uint32 0\n\n[org/gnome/desktop/screensaver]\nlock-enabled=false\n\n[org/gnome/shell]\nstartup-mode="user"\n' \
    > /etc/dconf/db/local.d/00-demo-settings && \
    printf '/org/gnome/desktop/session/idle-delay\n/org/gnome/desktop/screensaver/lock-enabled\n' \
    > /etc/dconf/db/local.d/locks/00-demo-settings && \
    dconf update


# Disable GNOME welcome tour
RUN mkdir -p /etc/xdg/autostart && \
    printf '[Desktop Entry]\nHidden=true\n' > /etc/xdg/autostart/org.gnome.Tour.desktop


# Create systemd user service directory
RUN mkdir -p /var/home/demouser/.config/systemd/user


# Demo browser service
RUN printf '[Unit]\nDescription=Launch Demo Browser\nAfter=graphical-session.target\n\n[Service]\nType=oneshot\nExecStart=/usr/bin/firefox --no-remote --kiosk http://127.0.0.1:6080\n\n[Install]\nWantedBy=default.target\n' \
> /var/home/demouser/.config/systemd/user/demo-browser.service


# Delay browser launch
RUN printf '[Unit]\nDescription=Delay Demo Browser Launch\n\n[Timer]\nOnBootSec=5\nUnit=demo-browser.service\n\n[Install]\nWantedBy=timers.target\n' \
> /var/home/demouser/.config/systemd/user/demo-browser.timer


# Fix ownership
RUN chown -R demouser:demouser /var/home/demouser/.config


# Enable user timer
RUN su - demouser -c "systemctl --user enable demo-browser.timer"


# Prevent OS auto-updates during conference
RUN systemctl mask bootc-fetch-apply-updates.timer


# Prevent container auto-updates
RUN systemctl mask podman-auto-update.timer
RUN systemctl mask podman-auto-update.service
